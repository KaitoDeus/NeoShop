{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile",
    "contextRelativePath": "backend"
  },
  "deploy": {
    "startCommand": "java -jar target/neoshop-backend-0.0.1-SNAPSHOT.jar --spring.profiles.active=prod",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
